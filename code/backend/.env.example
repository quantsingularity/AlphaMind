# ── Database ──────────────────────────────────────────────────────────────────
# Development (SQLite — no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./alphamind.db

# Production (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://alphamind:secret@localhost:5432/alphamind

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=info
SQL_ECHO=false

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# ── Market Data (optional — falls back to synthetic when absent) ───────────────
POLYGON_API_KEY=
ALPHA_VANTAGE_API_KEY=
TIINGO_API_KEY=

# ── Messaging ─────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Cloud / ML ────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=
VERTEX_AI_REGION=us-central1
