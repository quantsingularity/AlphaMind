{
  "expo": {
    "name": "AlphaMindMobile",
    "slug": "AlphaMindMobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6200EE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alphamind.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6200EE"
      },
      "package": "com.alphamind.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "_comment": "Set apiBaseUrl here (or EXPO_PUBLIC_API_BASE_URL) to point at a specific backend. When unset, the app defaults to http://localhost:8000 on web/iOS and http://10.0.2.2:8000 on the Android emulator."
    },
    "plugins": []
  }
}
