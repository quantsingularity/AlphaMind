# Copy to .env.local for local development

# Axios base URL for API calls.
# Leave EMPTY (the default) to issue relative /api/... requests that flow
# through the Vite dev proxy (dev) or the Nginx /api proxy (production).
# Set to an absolute URL (e.g. http://localhost:8000) only to bypass the proxy
# and call the backend directly.
VITE_API_BASE_URL=

# Dev-only: where the Vite dev server forwards /api and /health requests.
# Defaults to http://localhost:8000 (the backend's default API_PORT).
VITE_DEV_PROXY_TARGET=http://localhost:8000
