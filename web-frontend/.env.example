# ── API Configuration ────────────────────────────────────────────────────────
# Base URL for the AlphaMind backend API
VITE_API_BASE_URL=http://localhost:5000

# ── Environment ──────────────────────────────────────────────────────────────
VITE_ENV=development

# ── Feature Flags ────────────────────────────────────────────────────────────
# Set to true to use mock data when the backend is unavailable
VITE_ENABLE_MOCK_DATA=true
